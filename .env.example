# Your Sarvam API subscription key (from dashboard.sarvam.ai).
# Server-side only — never exposed to the browser.
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: your n8n ingestion webhook URL, if you route uploads through n8n.
# NEXT_PUBLIC_N8N_INGEST_URL=https://your-instance.app.n8n.cloud/webhook/lumen-ingest
